# --- Build output (regenerable; excluded from version control) ---
/build/
build/
*.o
*.obj
*.exe
*.pdb
*.ilk
*.lib
*.a
*.dll

# CMake scratch
CMakeUserPresets.json
/cmake-build-*/

# --- Generated debug/trace runtime output ---
# The debug/ tree is created at runtime by the emulator (traces, logs, frames,
# audio). Keep the directory scaffolding but do not track generated captures.
/debug/**/*.trace
/debug/**/*.log
/debug/**/*.txt
/debug/**/*.png
/debug/**/*.wav
/debug/**/*.bin

# M26 exception: one real, committed decoded-FrameBuffer-capture example
# (backlog C9's authorized debug/testing capability, docs/m26-planner-
# package.md §2.5) -- genuine evidence, not a regenerable runtime artifact.
!/debug/frames/m26-example-boot.png
!/debug/frames/m26-example-boot.frame

# --- Editor / IDE / OS cruft ---
.vs/
*.user
.idea/
.vscode/*.log
Thumbs.db
Desktop.ini
.DS_Store

