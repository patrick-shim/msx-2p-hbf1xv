# --- Build output (regenerable; excluded from version control) ---
# M33 single-build policy (DEC-0041): ONE canonical CMake tree at /build/.
# The /build*/ pattern also swallows any legacy per-agent tree (build-qa-*,
# build-m31-sdl, ...) so they can never reappear as repo noise — but creating
# them is itself a policy violation; agents must reuse /build/.
/build*/
build/
/build-*.log
*.o
*.obj
*.exe
*.pdb
*.ilk
*.lib
*.a
*.dll

# DEC-0030 exception: the fMSX 6.0 reference executable (human-provided
# cross-reference asset, references/fmsx-60/ -- NOT a build output).
!/references/fmsx-60/executables/fMSX.exe

# M53 (DEC-0080): the msx-diskutil host tool is a build product, post-build-copied
# from the ONE build/ tree; ignore the binary, keep the folder scaffolding.
# (The global *.exe rule already covers the .exe; the no-extension line covers
# the POSIX binary and is listed for discoverability.)
/utils/msx-diskutil
/utils/msx-diskutil.exe

# DEC-0097: the runtime settings file + File>Recent sidecar now live at the
# PROJECT ROOT (beside the assets they name, identical on every platform --
# the exe dir is build/Debug on Windows but build/ elsewhere). They are
# PER-MACHINE generated state: the emulator writes them, they carry absolute
# asset paths resolved on THIS machine, and committing one would push a
# Windows path onto the Mac/Pi and break their asset resolution. Never track.
/sony_msx_hbf1xv.xml
/sony_msx_recent.txt

# Python bytecode
__pycache__/
*.pyc

# CMake scratch
CMakeUserPresets.json
/cmake-build-*/

# --- Generated debug/trace runtime output ---
# The debug/ tree is created at runtime by the emulator (traces, logs, frames,
# audio). Keep the directory scaffolding but do not track generated captures.
/debug/**/*.trace
/debug/**/*.log
/debug/**/*.txt
/debug/**/*.png
/debug/**/*.wav
/debug/**/*.bin
/debug/**/*.dump
/debug/**/*.frame
/debug/**/*.script
/debug/**/frame_dump
/debug/**/emulator.out
/debug/**/emulator.log
# M36 playtest harness run dirs (timestamped, ephemeral capture output)
/debug/playtest_*/
# M36 Phase 3 comprehensive debug snapshots (per-component captures under
# debug/snapshot/<id>/ -- deterministic but regenerable runtime output; the
# blanket dir ignore also catches arbitrary-extension files like manifest.txt).
/debug/snapshot/
# DEC-0052 live stream-capture output: per-frame snapshot bundles under
# debug/snapshot/stream_<id>/ (already caught by /debug/snapshot/ above) and the
# per-instruction trace ring dump debug/traces/stream_<id>_trace.txt (already
# caught by /debug/**/*.txt above). Listed explicitly for discoverability.
/debug/snapshot/stream_*/
/debug/traces/stream_*_trace.txt

